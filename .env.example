# ── OpsPanel configuration ───────────────────────────────────────────────────
# Copy this file to .env and fill in the values. The app FAILS CLOSED in
# production: it will not start without JWT_SECRET and PANEL_MASTER_KEY.
#
# Generate strong secrets with:  openssl rand -hex 32

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection. For the bundled docker-compose, the host/port are managed
# for you; set PANEL_PG_PASSWORD instead (below) and this is derived.
DATABASE_URL="postgresql://panel:panel@localhost:5544/panel?schema=public"

# Signs session JWTs. MUST be >= 32 chars. Anyone who knows this can forge admin
# sessions — keep it secret, rotate if leaked.
JWT_SECRET="REPLACE_ME_with_openssl_rand_hex_32"

# Encrypts secrets at rest (SSH keys, TOTP secrets, integration creds). MUST be
# >= 16 chars. If you lose it, stored secrets become undecryptable.
PANEL_MASTER_KEY="REPLACE_ME_with_openssl_rand_hex_32"

# ── Required for docker-compose.prod.yml ──────────────────────────────────────
# (the prod compose reads these to build DATABASE_URL and the secrets above)
PANEL_PG_PASSWORD="REPLACE_ME_strong_db_password"
PANEL_JWT_SECRET="REPLACE_ME_with_openssl_rand_hex_32"

# ── Optional ──────────────────────────────────────────────────────────────────

# Redis (login rate-limiting, streams). Defaults to the bundled redis service.
REDIS_URL="redis://localhost:6390"

# Host Docker socket for container monitoring.
DOCKER_SOCKET="/var/run/docker.sock"

# Host ports for the local dev docker-compose stack. Override to avoid
# collisions with anything else already running on this machine.
# PG_PORT=5544
# REDIS_PORT=6390
# APP_PORT=3004

# Branding shown in the UI and TOTP issuer. Defaults to "OpsPanel".
APP_NAME="OpsPanel"

# Label for the local host in the Port Map / Servers views.
PANEL_LOCAL_HOST="local"

# Directory the panel deploys/reads on the host (Infrastructure Deploy,
# Discovery, Code Benchmarks). Point at your app's docker-compose project.
INFRA_DEPLOY_DIR="/opt/app"

# Colon-separated dirs scanned for docker-compose files in Discovery.
# COMPOSE_SCAN_DIRS="/opt:/srv"

# First-run admin bootstrap (seed). If ADMIN_PASSWORD is unset, a random
# password is generated and printed once. Change it after first login.
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD=""
