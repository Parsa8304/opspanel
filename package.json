{
  "name": "panel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "test:containers": "tsx --test tests/containers.test.ts",
    "test:qa": "tsx --test tests/qa.test.ts",
    "test:deployments": "tsx --test tests/deployments.test.ts",
    "test:tests": "tsx --test tests/tests-section.test.ts",
    "test:async": "tsx --test tests/async.test.ts",
    "test:integrations": "tsx --test tests/integrations.test.ts",
    "test:benchmarks": "tsx --test tests/benchmarks.test.ts",
    "test:aiquality": "tsx --test tests/aiquality.test.ts",
    "test:access": "tsx --test tests/access.test.ts",
    "test:reports": "tsx --test tests/reports.test.ts",
    "test:overview": "tsx --test tests/overview.test.ts",
    "test:discovery": "tsx --test tests/discovery.test.ts",
    "test:ports": "tsx --test tests/ports.test.ts",
    "test:alerts": "tsx --test tests/alerts.test.ts",
    "test:billing": "tsx --test tests/billing.test.ts",
    "test:deploy": "tsx --test tests/deploy.test.ts",
    "test:migration": "tsx --test tests/migration.test.ts",
    "test": "for t in containers qa deployments tests async integrations benchmarks aiquality access reports overview discovery ports alerts billing deploy migration; do echo \"=== $t ===\"; npm run -s test:$t || exit 1; done"
  },
  "dependencies": {
