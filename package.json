    "next": "14.2.35",
    "node-ssh": "^13.2.1",
    "prisma": "^6.19.3",
    "puppeteer-core": "^25.0.4",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "simple-git": "^3.36.0",
    "swr": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
