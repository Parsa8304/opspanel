generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String
  passwordHash      String
  role              Role             @default(READONLY)
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  totpSecret        String?
  totpEnabled       Boolean          @default(false)
  verifiedScenarios AccessScenario[]
  reviewedSamples   AiSample[]
  auditLogs         AuditLog[]
  deployments       Deployment[]
  verifiedItems     RegressionItem[]
  releases          Release[]
  reports           Report[]
  sessions          Session[]
}

model Session {
  id         String    @id @default(cuid())
  tokenId    String    @unique
  userId     String
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

model AccessScenario {
  id             String      @id @default(cuid())
  name           String
  description    String
  status         CheckStatus @default(STALE)
  lastVerifiedAt DateTime?
  verifiedById   String?
  staleAfterDays Int         @default(30)
  notes          String?
  updatedAt      DateTime    @updatedAt
  verifiedBy     User?       @relation(fields: [verifiedById], references: [id])
}

model RegressionItem {
  id             String      @id @default(cuid())
  module         QaModule
  title          String
  testSteps      String?
  environment    Environment @default(DEMO)
  status         CheckStatus @default(STALE)
  lastVerifiedAt DateTime?
  verifiedById   String?
  staleAfterDays Int         @default(30)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  evidence       Evidence[]
  verifiedBy     User?       @relation(fields: [verifiedById], references: [id])
}

model Evidence {
  id               String         @id @default(cuid())
  regressionItemId String
  type             EvidenceType
  url              String
  label            String?
  createdAt        DateTime       @default(now())
  regressionItem   RegressionItem @relation(fields: [regressionItemId], references: [id], onDelete: Cascade)
}

model CoverageItem {
  id        String         @id @default(cuid())
  title     String
  area      String
  owner     String?
  status    CoverageStatus @default(NOT_STARTED)
  deadline  DateTime?
  notes     String?
  blockers  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Integration {
  id                  String                @id @default(cuid())
  key                 String                @unique
  name                String
  category            String
  enabled             Boolean               @default(false)
  config              Json?
  credentialExpiresAt DateTime?
  createdAt           DateTime              @default(now())
  calls               IntegrationCall[]
  incidents           IntegrationIncident[]
}

model IntegrationCall {
  id            String      @id @default(cuid())
  integrationId String
  success       Boolean
  statusCode    Int?
  latencyMs     Int?
  costUsd       Float?
  error         String?
  createdAt     DateTime    @default(now())
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
}

model IntegrationIncident {
  id            String      @id @default(cuid())
  integrationId String
  title         String
  description   String?
  severity      String      @default("minor")
  startedAt     DateTime    @default(now())
  resolvedAt    DateTime?
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model JobRecord {
  id          String    @id @default(cuid())
  taskId      String    @unique
  taskType    String
  queue       String    @default("default")
  status      JobStatus @default(PENDING)
  workerName  String?
  durationMs  Int?
  error       String?
  payloadMeta Json?
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([taskType, createdAt])
  @@index([status])
}

model Deployment {
  id           String      @id @default(cuid())
  environment  Environment
  commitSha    String
  version      String?
  status       String      @default("active")
  deployedById String?
  rollbackOfId String?
  deployedAt   DateTime    @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  logUrl       String?
  deployedBy   User?       @relation(fields: [deployedById], references: [id])

  @@index([environment, deployedAt])
}

model Release {
  id           String   @id @default(cuid())
  version      String   @unique
  commitSha    String
  changelog    String?
  deployedById String?
  date         DateTime @default(now())
  deployedBy   User?    @relation(fields: [deployedById], references: [id])
}

model TestRun {
  id         String     @id @default(cuid())
  commitSha  String?
  source     String     @default("manual")
  ciUrl      String?
  total      Int        @default(0)
  passed     Int        @default(0)
  failed     Int        @default(0)
  skipped    Int        @default(0)
  durationMs Int        @default(0)
  startedAt  DateTime   @default(now())
  finishedAt DateTime?
  cases      TestCase[]

  @@index([commitSha])
  @@index([startedAt])
}

model TestCase {
  id             String         @id @default(cuid())
  testRunId      String
  name           String
  classname      String?
  type           TestType       @default(UNIT)
  status         TestCaseStatus
  durationMs     Int            @default(0)
  failureMessage String?
  failureTrace   String?
  testRun        TestRun        @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([testRunId])
}

model CoverageMetric {
  id        String   @id @default(cuid())
  commitSha String?
  module    String
  linesPct  Float
  createdAt DateTime @default(now())

  @@index([module, createdAt])
}

model CodeMetric {
  id             String   @id @default(cuid())
  commitSha      String
  loc            Int?
  cyclomatic     Float?
  duplicationPct Float?
  lintWarnings   Int?
  typeErrors     Int?
  buildTimeMs    Int?
  bundleBytes    Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model ApiBenchmark {
  id        String   @id @default(cuid())
  endpoint  String
  p50Ms     Float
  p95Ms     Float
  p99Ms     Float
  commitSha String?
  createdAt DateTime @default(now())

  @@index([endpoint, createdAt])
}

model AiCostMetric {
  id        String   @id @default(cuid())
  module    String
  model     String
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  costUsd   Float    @default(0)
  latencyMs Int?
  commitSha String?
  createdAt DateTime @default(now())

  @@index([module, createdAt])
}

model AiSample {
  id           String       @id @default(cuid())
  module       String
  model        String
  modelVersion String?
  inputText    String
  outputText   String
  humanRating  Int?
  notes        String?
  costUsd      Float?
  latencyMs    Int?
  flag         AiFlag       @default(NONE)
  reviewStatus ReviewStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime     @default(now())
  reviewedBy   User?        @relation(fields: [reviewedById], references: [id])

  @@index([module, createdAt])
}

model AiRegressionCase {
  id             String            @id @default(cuid())
  module         String
  inputText      String
  expectedNote   String?
  baselineOutput String?
  baselineModel  String?
  createdAt      DateTime          @default(now())
  runs           AiRegressionRun[]
}

model PromptVersion {
  id          String    @id @default(cuid())
  module      String
  name        String
  version     Int       @default(1)
  template    String
  variables   String[]  @default([])
  notes       String?
  deployedAt  DateTime?
  testResults Json?
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([module, name, version])
  @@index([module, createdAt])
}

model FallbackPolicy {
  id                  String       @id @default(cuid())
  module              String       @unique
  primaryModel        String
  fallbackModel       String
  fallbackKind        FallbackKind @default(CHEAP_MODEL)
  triggerOnError      Boolean      @default(true)
  triggerOnTimeout    Boolean      @default(false)
  triggerOnHighCost   Boolean      @default(false)
  triggerOnLowQuality Boolean      @default(false)
  maxRetries          Int          @default(1)
  timeoutMs           Int?
  costThresholdUsd    Float?
  qualityThreshold    Float?
  enabled             Boolean      @default(true)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model AiRegressionRun {
  id         String           @id @default(cuid())
  caseId     String
  model      String
  output     String
  costUsd    Float?
  latencyMs  Int?
  matchScore Float?
  createdAt  DateTime         @default(now())
  case       AiRegressionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Report {
  id          String     @id @default(cuid())
  title       String
  mode        ReportMode @default(INTERNAL)
  language    ReportLang @default(EN)
  version     Int        @default(1)
  sections    Json
  snapshot    Json
  createdById String?
  createdAt   DateTime   @default(now())
  createdBy   User?      @relation(fields: [createdById], references: [id])

  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model RemoteServer {
  id          String    @id @default(cuid())
  name        String
  host        String
  port        Int       @default(22)
  sshUser     String
  privateKey  String // encrypted via lib/crypto.ts (v1:...)
  passphrase  String? // encrypted via lib/crypto.ts, optional
  fingerprint String? // SHA256 host key fingerprint, captured on first successful connect
  tags        String[]  @default([])
  lastOkAt    DateTime?
  lastError   String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
}

model BackgroundJob {
  id          String    @id @default(cuid())
  kind        String
  label       String
  state       JobState  @default(QUEUED)
  progress    Int       @default(0)
  params      Json?
  result      Json?
  error       String?
  log         String    @default("")
  createdById String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([kind, createdAt])
  @@index([state])
}

model Host {
  name           String           @id
  address        String
  sshUser        String           @default("root")
  sshPort        Int              @default(22)
  sshKeyEnc      String?
  os             String?
  totalRamMb     Int?
  totalCpu       Int?
  totalDiskGb    Int?
  isLocal        Boolean          @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime         @default(now())
  migrationsFrom MigrationPlan[]  @relation("MigrationSource")
  migrationsTo   MigrationPlan[]  @relation("MigrationTarget")
  ports          PortAllocation[]
}

model PortAllocation {
  id            String   @id @default(cuid())
  hostName      String
  serverId      String   @default("local")
  port          Int
  protocol      String   @default("tcp")
  iface         String   @default("0.0.0.0")
  processName   String?
  serviceName   String?
  containerName String?
  discoveredVia String   @default("docker")
  isPublic      Boolean  @default(false)
  status        String   @default("active")
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @default(now())
  host          Host     @relation(fields: [hostName], references: [name], onDelete: Cascade)

  @@unique([serverId, hostName, port, protocol, iface])
  @@index([hostName])
  @@index([serverId])
}

model DiscoveryProposal {
  id          String    @id @default(cuid())
  kind        String
  title       String
  description String
  proposed    Json
  evidence    Json?
  status      String    @default("pending")
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
}

model AlertChannel {
  id          String          @id @default(cuid())
  type        String
  name        String
  configEnc   String
  enabled     Boolean         @default(true)
  minSeverity AlertSeverity   @default(INFO)
  createdAt   DateTime        @default(now())
  events      AlertDelivery[]
}

model AlertRule {
  id            String        @id @default(cuid())
  name          String
  source        String
  containerName String?
  pattern       String?
  threshold     Int?
  windowSec     Int?
  severity      AlertSeverity @default(ERROR)
  cooldownSec   Int           @default(300)
  enabled       Boolean       @default(true)
  builtin       Boolean       @default(false)
  lastFiredAt   DateTime?
  createdAt     DateTime      @default(now())
  events        AlertEvent[]
}

model AlertEvent {
  id              String          @id @default(cuid())
  ruleId          String?
  severity        AlertSeverity
  source          String
  title           String
  payload         Json?
  suppressedCount Int             @default(0)
  ackStatus       String          @default("open")
  ackById         String?
  ackedAt         DateTime?
  snoozeUntil     DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  deliveries      AlertDelivery[]
  rule            AlertRule?      @relation(fields: [ruleId], references: [id])

  @@index([ackStatus, createdAt])
  @@index([createdAt])
}

model AlertDelivery {
  id          String       @id @default(cuid())
  eventId     String
  channelId   String
  status      String       @default("pending")
  attempts    Int          @default(0)
  lastError   String?
  deliveredAt DateTime?
  createdAt   DateTime     @default(now())
  channel     AlertChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  event       AlertEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
}

model BillingEvent {
  id                    String   @id @default(cuid())
  provider              String
  model                 String?
  endpoint              String?
  generationId          String?  @unique
  requestId             String?
  requestAt             DateTime @default(now())
  tokensIn              Int      @default(0)
  tokensOut             Int      @default(0)
  tokensReasoning       Int      @default(0)
  tokensCached          Int      @default(0)
  unitCost              Float?
  totalCost             Float    @default(0)
  currency              String   @default("USD")
  module                String   @default("unknown")
  feature               String?
  environment           String?
  userId                String?
  projectId             String?
  isByok                Boolean  @default(false)
  isFreeTier            Boolean  @default(false)
  upstreamInferenceCost Float?
  rawMeta               Json?
  createdAt             DateTime @default(now())

  @@index([provider, requestAt])
  @@index([module, requestAt])
  @@index([requestAt])
  @@index([environment, requestAt])
}

model BillingBudget {
  id             String   @id @default(cuid())
  provider       String
  period         String
  limitAmount    Float
  currency       String   @default("USD")
  thresholds     Int[]    @default([50, 80, 100])
  actionOnBreach String   @default("alert")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([provider, period])
}

model ProviderPricing {
  id                String    @id @default(cuid())
  provider          String
  model             String
  inPricePerM       Float
  outPricePerM      Float
  cachedInPricePerM Float?
  effectiveFrom     DateTime  @default(now())
  effectiveTo       DateTime?
  createdAt         DateTime  @default(now())

  @@index([provider, model, effectiveFrom])
}

model ProviderCredential {
  id            String    @id @default(cuid())
  provider      String
  credType      String
  keyEnc        String
  scopeNotes    String?
  rotationDueAt DateTime?
  createdAt     DateTime  @default(now())

  @@unique([provider, credType])
}

model ModuleBudget {
  id          String   @id @default(cuid())
  module      String
  period      String
  limitAmount Float
  currency    String   @default("USD")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([module, period])
  @@index([module])
}

model ReconciliationRun {
  id            String   @id @default(cuid())
  provider      String
  forDate       DateTime
  capturedTotal Float
  providerTotal Float
  driftAbs      Float
  driftPct      Float
  flagged       Boolean  @default(false)
  breakdown     Json?
  status        String   @default("ok")
  error         String?
  createdAt     DateTime @default(now())

  @@unique([provider, forDate])
  @@index([createdAt])
}

model ReleaseChecklist {
  id          String                 @id @default(cuid())
  version     String
  environment Environment
  title       String?
  createdAt   DateTime               @default(now())
  items       ReleaseChecklistItem[]

  @@index([version, environment])
}

model ReleaseChecklistItem {
  id          String            @id @default(cuid())
  checklistId String
  title       String
  description String?
  kind        ChecklistItemKind @default(MANUAL)
  priority    ChecklistPriority @default(P1)
  status      CheckStatus       @default(STALE)
  owner       String?
  reviewer    String?
  verifiedAt  DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  checklist   ReleaseChecklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model QualityGate {
  id              String      @id @default(cuid())
  environment     Environment @unique
  minPassRate     Float       @default(0.8)
  requireP0Checks Boolean     @default(true)
  blockOnFailing  Boolean     @default(true)
  enabled         Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model DeployRun {
  id               String            @id @default(cuid())
  environment      Environment
  commitSha        String
  service          String?
  strategy         String            @default("blue_green")
  state            JobState          @default(QUEUED)
  jobId            String?
  migrations       Json?
  rolledBack       Boolean           @default(false)
  deploymentId     String?
  triggeredById    String?
  log              String            @default("")
  startedAt        DateTime          @default(now())
  finishedAt       DateTime?
  healthStatus     String            @default("pending")
  healthPort       Int?
  postDeployChecks PostDeployCheck[]

  @@index([environment, startedAt])
}

model PostDeployCheck {
  id          String    @id @default(cuid())
  deployRunId String
  url         String
  httpStatus  Int?
  durationMs  Int?
  ok          Boolean
  checkedAt   DateTime  @default(now())
  error       String?
  deployRun   DeployRun @relation(fields: [deployRunId], references: [id])

  @@index([deployRunId, checkedAt])
}

model MigrationPlan {
  id               String    @id @default(cuid())
  sourceHostName   String
  targetHostName   String
  service          String
  volumes          String[]  @default([])
  strategy         String
  expectedDowntime String?
  status           String    @default("planned")
  jobId            String?
  preflight        Json?
  restorePoint     String?
  log              String    @default("")
  startedAt        DateTime?
  completedAt      DateTime?
  createdById      String?
  createdAt        DateTime  @default(now())
  sourceHost       Host      @relation("MigrationSource", fields: [sourceHostName], references: [name])
  targetHost       Host      @relation("MigrationTarget", fields: [targetHostName], references: [name])

  @@index([status, createdAt])
}

model BackupSchedule {
  id          String           @id @default(cuid())
  name        String
  serverId    String           @default("local")
  targetKind  BackupTargetKind
  targetRef   String
  cronExpr    String
  retainDays  Int              @default(7)
  destination String           @default("local")
  enabled     Boolean          @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime         @default(now())
  jobs        BackupJob[]

  @@index([serverId])
}

model BackupJob {
  id            String           @id @default(cuid())
  scheduleId    String?
  serverId      String           @default("local")
  targetKind    BackupTargetKind
  targetRef     String
  status        BackupStatus     @default(PENDING)
  sizeBytes     BigInt?
  path          String?
  destination   String           @default("local")
  log           String?
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  expiresAt     DateTime?
  triggeredById String?
  createdAt     DateTime         @default(now())
  schedule      BackupSchedule?  @relation(fields: [scheduleId], references: [id])

  @@index([serverId])
}

model Domain {
  id            String    @id @default(cuid())
  name          String    @unique
  serverId      String    @default("local")
  service       String?
  proxyTarget   String?
  sslStatus     SslStatus @default(UNKNOWN)
  sslExpiry     DateTime?
  sslIssuer     String?
  sslAutoRenew  Boolean   @default(false)
  dnsStatus     DnsStatus @default(UNKNOWN)
  dnsResolvesTo String?
  lastCheckedAt DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([serverId])
}

model Runbook {
  id          String          @id @default(cuid())
  title       String
  description String?
  category    RunbookCategory @default(GENERAL)
  steps       Json
  tags        String[]
  enabled     Boolean         @default(true)
  lastUsedAt  DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  runs        RunbookRun[]
}

model RunbookRun {
  id            String           @id @default(cuid())
  runbookId     String
  status        RunbookRunStatus @default(RUNNING)
  triggeredById String?
  notes         String?
  stepProgress  Int              @default(0)
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  runbook       Runbook          @relation(fields: [runbookId], references: [id], onDelete: Cascade)
}

model EnvSnapshot {
  id          String   @id @default(cuid())
  environment String
  service     String
  key         String
  value       String?
  masked      Boolean  @default(false)
  capturedAt  DateTime @default(now())

  @@index([environment, service])
}

enum Role {
  ADMIN
  ENGINEER
  REVIEWER
  READONLY
}

enum CheckStatus {
  PASSING
  FAILING
  STALE
}

enum QaModule {
  LOGIN
  PROJECT_MANAGEMENT
  QUICK_REPORT
  DECISION_ENGINE
  GTM_STRATEGY
  PITCH_DECK
  PITCH_TO_VC
  FIND_EXPERTS
  AI_RESEARCH_ASSISTANT
  ASYNC_PROCESSING
  WEBSOCKET
  STORAGE
  SEARCH
  EXTERNAL_INTEGRATIONS
  AI_INTEGRATIONS
  ACCESS_CONTROL
  DEPLOYMENT
  OVERALL_READINESS
}

enum Environment {
  DEV
  STAGING
  DEMO
  OPERATIONAL
  PROD
}

enum EvidenceType {
  SCREENSHOT
  VIDEO
  TEST_OUTPUT
  LOG_LINK
}

enum CoverageStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum JobStatus {
  PENDING
  STARTED
  SUCCESS
  FAILURE
  RETRY
  DEAD
}

enum TestType {
  UNIT
  INTEGRATION
  E2E
  API
  FRONTEND
  WORKER
}

enum TestCaseStatus {
  PASSED
  FAILED
  SKIPPED
}

enum AiFlag {
  NONE
  HALLUCINATION
  REFUSAL
  ERROR
}

enum ReviewStatus {
  PENDING
  REVIEWED
}

enum FallbackKind {
  CHEAP_MODEL
  HIGH_QUALITY_MODEL
  LOCAL
  DETERMINISTIC
}

enum ReportMode {
  INTERNAL
  REVIEWER
}

enum ReportLang {
  EN
  FA
}

enum JobState {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  ROLLED_BACK
  CANCELLED
}

enum AlertSeverity {
  INFO
  WARN
  ERROR
  CRITICAL
}

enum ChecklistItemKind {
  MANUAL
  AUTOMATED
}

enum ChecklistPriority {
  P0
  P1
  P2
}

enum BackupTargetKind {
  DATABASE
  VOLUME
  CONFIG
  UPLOAD
  FULL
}

enum BackupStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  EXPIRED
}

enum DnsStatus {
  UNKNOWN
  OK
  MISMATCH
  UNREACHABLE
}

enum SslStatus {
  UNKNOWN
  VALID
  EXPIRING_SOON
  EXPIRED
  INVALID
}

